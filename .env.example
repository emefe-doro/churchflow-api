APP_NAME=ChurchFlow AI
APP_VERSION=0.1.0
DEBUG=false

DATABASE_URL=postgresql+asyncpg://churchflow:churchflow@localhost:5432/churchflow
DATABASE_URL_SYNC=postgresql+psycopg2://churchflow:churchflow@localhost:5432/churchflow

REDIS_URL=redis://localhost:6379/0

WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=churchflow-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_MAX_RETRY_ATTEMPTS=3
WHATSAPP_RETRY_DELAY_SECONDS=300

AI_PROVIDER=deepseek
AI_API_KEY=
AI_API_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=512
AI_TEMPERATURE=0.7
AI_TIMEOUT_SECONDS=30
AI_FALLBACK_TO_TEMPLATE=true

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=["http://localhost:3000"]

LOG_LEVEL=INFO
